APP_NAME="Automated Ransomware Containment & IR Orchestrator"
APP_ENV=development
WEBHOOK_SECRET=change_this_secret
DATABASE_URL=sqlite:///./ir_orchestrator.db
LOCAL_S3_BUCKET=local_s3_bucket

USE_REAL_EDR=false
USE_REAL_IDP=false
REQUIRE_MANUAL_APPROVAL=true

ALLOWED_TEST_HOSTS=DESKTOP-LAB-01,DESKTOP-LAB-02,DESKTOP-LAB-20
ALLOWED_TEST_USERS=test.ir.user

MDE_TENANT_ID=change_me
MDE_CLIENT_ID=change_me
MDE_CLIENT_SECRET=change_me
MDE_API_BASE_URL=https://api.security.microsoft.com
MDE_AUTHORITY_URL=https://login.microsoftonline.com
MDE_SCOPE=https://api.securitycenter.microsoft.com/.default

GRAPH_TENANT_ID=change_me
GRAPH_CLIENT_ID=change_me
GRAPH_CLIENT_SECRET=change_me
GRAPH_API_BASE_URL=https://graph.microsoft.com/v1.0
GRAPH_AUTHORITY_URL=https://login.microsoftonline.com
GRAPH_SCOPE=https://graph.microsoft.com/.default

REAL_ACTION_APPROVAL_CODE=change_this_approval_code